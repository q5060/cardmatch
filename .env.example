# Copy to .env for local development:
#   cp .env.example .env

# PostgreSQL (start with: docker compose -f docker-compose.db.yml up -d)
DATABASE_URL="postgresql://cardmatch:cardmatch@localhost:5432/cardmatch"
# Migrations use directUrl; local dev can match DATABASE_URL.
DIRECT_DATABASE_URL="postgresql://cardmatch:cardmatch@localhost:5432/cardmatch"

SESSION_SECRET="change-me-to-at-least-32-random-characters-long"

# Public site URL for battle result share links and Open Graph (production)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Password reset emails (required in production)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-smtp-user"
SMTP_PASS="your-smtp-password"
SMTP_FROM="CardMatch <noreply@example.com>"

# Local dev: in-memory realtime (single process)
REALTIME_BUS=memory

# Vercel production: use Upstash Redis
# REALTIME_BUS=redis
# REDIS_URL="rediss://default:YOUR_PASSWORD@YOUR_ENDPOINT.upstash.io:6379"
