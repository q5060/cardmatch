generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums stored as strings; validate in app with TS unions in lib/constants.ts

model User {
  id              Int      @id @default(autoincrement())
  email           String   @unique
  passwordHash    String
  displayName     String
  bio             String   @default("")
  avatarUrl       String?
  bannerUrl       String?  // 個人檔案橫幅
  defaultShopId   String?  // 常去的店家
  
  // 隱私設定
  battleRecordVisibility String @default("PUBLIC") // PUBLIC | FRIENDS | PRIVATE
  winrateVisibility      String @default("PUBLIC") // PUBLIC | FRIENDS | PRIVATE
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  decks              Deck[]
  meetSpots          MeetSpot[]
  matchesAsPlayerA   Match[]          @relation("PlayerA")
  matchesAsPlayerB   Match[]          @relation("PlayerB")
  messages           Message[]
  friendMessages     FriendMessage[]
  friendshipsSent    Friendship[]     @relation("Requester")
  friendshipsRecv    Friendship[]     @relation("Addressee")
  battleResults      BattleResult[]
  notifications      Notification[]
  matchQueueEntries  MatchQueueEntry[]
  reportsMade        UserReport[]     @relation("ReportsMade")
  reportsReceived    UserReport[]     @relation("ReportsReceived")
  blocksMade         UserBlock[]      @relation("BlocksMade")
  blocksReceived     UserBlock[]      @relation("BlocksReceived")
}

model UserReport {
  id         String   @id @default(cuid())
  reporterId Int
  reportedId Int
  reason     String   @default("")
  createdAt  DateTime @default(now())
  reporter   User     @relation("ReportsMade", fields: [reporterId], references: [id], onDelete: Cascade)
  reported   User     @relation("ReportsReceived", fields: [reportedId], references: [id], onDelete: Cascade)

  @@index([reportedId])
}

model UserBlock {
  blockerId Int
  blockedId Int
  createdAt DateTime @default(now())
  blocker   User @relation("BlocksMade", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User @relation("BlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)

  @@id([blockerId, blockedId])
}

model Deck {
  id         String   @id @default(cuid())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  notes      String   @default("")
  visibility String   @default("PUBLIC") // PUBLIC | FRIENDS | PRIVATE
  deckJson   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model MeetSpot {
  id        String    @id @default(cuid())
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lat       Float
  lng       Float
  label     String
  timeNote  String    @default("")
  playNote  String    @default("") // 約戰說明：格式、程度等
  active    Boolean   @default(true)
  looking   Boolean   @default(false)
  shopId    String?
  shop      Shop?     @relation(fields: [shopId], references: [id], onDelete: SetNull)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Shop {
  id                String     @id @default(cuid())
  name              String
  lat               Float
  lng               Float
  addressNote       String     @default("")
  hasPtcgBattleArea Boolean    @default(false)
  hoursJson         String     @default("{}")
  matches           Match[]
  meetSpots         MeetSpot[]
  matchQueueEntries MatchQueueEntry[]
  events            ShopEvent[]
}

model ShopEvent {
  id          String    @id @default(cuid())
  shopId      String
  shop        Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  title       String
  description String    @default("")
  startsAt    DateTime
  endsAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([shopId, startsAt])
}

model Match {
  id           Int      @id @default(autoincrement())
  playerAId    Int
  playerBId    Int
  playerA      User     @relation("PlayerA", fields: [playerAId], references: [id], onDelete: Cascade)
  playerB      User     @relation("PlayerB", fields: [playerBId], references: [id], onDelete: Cascade)
  invitedById  Int
  status       String   @default("INVITE_PENDING") // INVITE_PENDING | ACCEPTED | IN_PROGRESS | COMPLETED | CANCELLED
  playerAReady Boolean  @default(false)
  playerBReady Boolean  @default(false)
  cancelRequestedBy Int? // User who requested cancellation
  meetLat      Float
  meetLng      Float
  meetLabel    String
  shopId       String?
  shop         Shop?    @relation(fields: [shopId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  messages      Message[]
  battleResults BattleResult[]
}

model Message {
  id        String   @id @default(cuid())
  matchId   Int
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  senderId  Int
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())
}

model Friendship {
  id          String   @id @default(cuid())
  requesterId Int
  addresseeId Int
  requester   User     @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee   User     @relation("Addressee", fields: [addresseeId], references: [id], onDelete: Cascade)
  status      String   @default("PENDING") // PENDING | ACCEPTED
  messages    FriendMessage[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([requesterId, addresseeId])
}

model FriendMessage {
  id           String     @id @default(cuid())
  friendshipId String
  friendship   Friendship @relation(fields: [friendshipId], references: [id], onDelete: Cascade)
  senderId     Int
  sender       User       @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body         String
  createdAt    DateTime   @default(now())
}

model BattleResult {
  id            String   @id @default(cuid())
  matchId       Int      @unique
  match         Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  winnerId      Int?
  winner        User?    @relation(fields: [winnerId], references: [id], onDelete: Cascade)
  playerAAgreed Boolean  @default(false)
  playerBAgreed Boolean  @default(false)
  status        String   @default("PENDING") // PENDING | AGREED
  createdAt     DateTime @default(now())
}

model Notification {
  id          String   @id @default(cuid())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // SPOT_INVITE | MATCH_CREATED | MATCH_COMPLETED | FRIEND_REQUEST | MESSAGE | BATTLE_RESULT | etc
  referenceId String?  // References match ID, friendship ID, message ID, etc
  senderId    Int?     // For MESSAGE and other notifications with a sender
  data        String?  // JSON string for additional data like notification message
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
}

/// Random match queue: one row per user (userId unique). shopId null = match globally.
model MatchQueueEntry {
  id       String   @id @default(cuid())
  userId   Int      @unique
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopId   String?
  shop     Shop?    @relation(fields: [shopId], references: [id], onDelete: SetNull)
  playNote String   @default("")
  lat      Float?   // Map center latitude for random matching
  lng      Float?   // Map center longitude for random matching
  radiusKm Float?   // Search radius in km for random matching
  joinedAt DateTime @default(now())
}
