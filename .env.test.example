# Copy to .env.test for local tests:
#   cp .env.test.example .env.test
#
# Requires Postgres (e.g. docker compose -f docker-compose.db.yml up -d)
# and a separate test database:
#   docker compose -f docker-compose.db.yml exec postgres \
#     psql -U cardmatch -c "CREATE DATABASE cardmatch_test;"

DATABASE_URL="postgresql://cardmatch:cardmatch@localhost:5432/cardmatch_test"
DIRECT_DATABASE_URL="postgresql://cardmatch:cardmatch@localhost:5432/cardmatch_test"
SESSION_SECRET="test-session-secret-at-least-32-chars-long"
REALTIME_BUS=memory

# Production / multi-instance (Vercel + Upstash Redis)
# REALTIME_BUS=redis
# REDIS_URL="rediss://default:YOUR_PASSWORD@YOUR_ENDPOINT.upstash.io:6379"
